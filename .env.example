# App
NEXT_PUBLIC_APP_NAME="Velocidade Quase Máxima"
NEXT_PUBLIC_APP_SHORT_NAME="Velocidade"
NEXT_PUBLIC_APP_URL="https://velocidadequasemaxima.com.br"

# Admin
# Server-only. Never prefix with NEXT_PUBLIC_.
ADMIN_PASSWORD="change-me"
VIDEOMAKER_PASSWORD="change-me-too"

# Neon PostgreSQL
# Never commit real database credentials.
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require"

# Local Docker PostgreSQL used automatically by npm run dev:
# postgresql://velocidade:velocidade@localhost:54329/velocidade_dev?schema=public
