{
  "name": "sistema-campeonato-kart",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "scripts": {
    "dev": "node scripts/dev-local.mjs",
    "dev:next": "next dev",
    "dev:db": "docker compose up -d postgres",
    "dev:db:down": "docker compose down",
    "db:push:local": "DATABASE_URL=\"postgresql://velocidade:velocidade@localhost:54329/velocidade_dev?schema=public\" prisma db push",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "prisma:generate": "prisma generate",
    "prisma:validate": "DATABASE_URL=\"${DATABASE_URL:-postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require}\" prisma validate"
  },
  "dependencies": {
    "@prisma/client": "6.19.3",
    "lucide-react": "latest",
    "next": "latest",
    "pdf-parse": "^2.4.5",
    "react": "latest",
    "react-dom": "latest",
    "recharts": "^3.8.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "latest",
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "eslint": "latest",
    "eslint-config-next": "latest",
    "postcss": "latest",
    "prisma": "6.19.3",
    "tailwindcss": "latest",
    "typescript": "latest",
    "vitest": "^4.1.9"
  }
}
